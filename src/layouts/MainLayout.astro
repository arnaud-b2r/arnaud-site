---
/**
 * MainLayout.astro
 * Layout principal du site — utilisé par toutes les pages sauf les articles de blog.
 * Intègre : BaseHead, Header, Footer, et le slot de contenu.
 *
 * Props :
 * - title       : titre de la page (balise <title> + og:title)
 * - description : description meta (og:description)
 */
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

/*
  IMPORTANT — pourquoi on importe global.css ici plutôt qu'avec une balise <link> ?

  Quand on écrit <link rel="stylesheet" href="/styles/global.css" />, le navigateur
  cherche ce fichier à l'URL /styles/global.css. Cela ne fonctionne que si le fichier
  est physiquement dans le dossier public/. Astro ne le touche pas, ne le bundle pas,
  ne le hashe pas.

  Quand on importe le CSS ici dans le frontmatter, Astro l'intègre dans son pipeline
  de build : il le bundle avec les autres styles, lui ajoute un hash pour le cache,
  et injecte automatiquement la bonne balise <link> dans le HTML final.
  C'est la méthode fiable qui fonctionne identiquement en local et en production.

  Prérequis : global.css doit être dans src/styles/global.css (et non dans public/).
  Pour le déplacer depuis public/ : mv public/styles/global.css src/styles/global.css
*/
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <!--
      BaseHead gère tout le contenu du <head> :
      balises meta, og:, favicon, canonical URL, polices.
      On lui passe le titre et la description de la page courante.

      Le global.css est importé dans le frontmatter ci-dessus —
      Astro l'injecte automatiquement ici sous forme de <link> bundlé.
      Il ne faut donc plus de <link rel="stylesheet" href="/styles/global.css" /> ici.
    -->
    <BaseHead title={title} description={description} />
  </head>

  <body>
    <!-- Header commun à toutes les pages -->
    <Header />

    <main>
      <!--
        .container est défini dans global.css.
        Il centre le contenu et limite sa largeur à --content-width (860px).
        <slot /> est l'endroit où Astro injecte le contenu
        de chaque page qui utilise ce layout.
      -->
      <div class="container">
        <slot />
      </div>
    </main>

    <!-- Footer commun à toutes les pages -->
    <Footer />
  </body>
</html>
