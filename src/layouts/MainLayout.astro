---
/**
 * MainLayout.astro
 * Layout principal du site — utilisé par toutes les pages sauf les articles de blog.
 * Intègre : BaseHead, Header, Footer, et le slot de contenu.
 *
 * Props :
 * - title       : titre de la page (balise <title> + og:title)
 * - description : description meta (og:description)
 *
 * IMPORTANT — pourquoi pas de .container autour du <slot /> ?
 *
 * Avant, le slot était enveloppé dans <div class="container">, ce qui
 * limitait le contenu à --content-width et ajoutait du padding latéral
 * sur toutes les pages.
 *
 * Avec le nouveau design dark mode, la homepage a besoin d'occuper
 * toute la largeur de la fenêtre (hero pleine largeur, grille de cards
 * jointives bord à bord). Enfermer le slot dans .container empêchait cela.
 *
 * Chaque page gère maintenant sa propre largeur interne :
 * - index.astro   : pleine largeur, via .home-inner pour les sections centrées
 * - blog/index.astro : utilise sa propre class .blog-page + .container
 * - articles      : BlogPost.astro gère la largeur via .prose
 */
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

/*
  Pourquoi importer global.css ici plutôt qu'avec une balise <link> ?

  Quand on écrit <link rel="stylesheet" href="/styles/global.css" />, le navigateur
  cherche ce fichier à l'URL /styles/global.css. Cela ne fonctionne que si le fichier
  est physiquement dans public/. Astro ne le bundle pas, ne lui ajoute pas de hash.

  En important ici dans le frontmatter, Astro intègre le CSS dans son pipeline
  de build : il le bundle, lui ajoute un hash pour le cache, et injecte la bonne
  balise <link> dans le HTML final. Fiable en local et en production.
*/
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <!--
      BaseHead gère tout le contenu du <head> :
      balises meta, og:, favicon, canonical URL, polices.
    -->
    <BaseHead title={title} description={description} />
  </head>

  <body>
    <!-- Header commun à toutes les pages -->
    <Header />

    <!--
      <main> sans .container autour du slot.
      Chaque page est responsable de centrer et contraindre
      son propre contenu selon ses besoins.
    -->
    <main>
      <slot />
    </main>

    <!-- Footer commun à toutes les pages -->
    <Footer />
  </body>
</html>
