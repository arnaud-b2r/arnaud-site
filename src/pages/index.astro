---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
  <section class="home-grid">
    <article class="featured-card">
      <div class="featured-content">
        <p class="meta">MISE À JOUR : 11 MARS 2026 • SITE PERSONNEL</p>
        <h1>Site en cours de développement</h1>
        <p class="excerpt">
          Une nouvelle version du site arrive bientôt. En attendant, voici un aperçu
          de l’univers à venir : notes, projets, découvertes et réflexions.
        </p>
        <a href="/about" class="read-more">En savoir plus</a>
      </div>

      <div class="featured-visual">
        <img src="/images/carnet-bord_logo.png" alt="Carnet de bord" class="featured-logo" />
      </div>
    </article>

    <div class="cards-grid">
      <article class="post-card">
        <div class="card-visual visual-blue">
          <img src="/images/carnet-bord_logo.png" alt="" class="card-logo" />
        </div>
        <div class="card-body">
          <p class="card-meta">NOTES • À VENIR</p>
          <h2>Articles et billets</h2>
          <p>
            Des contenus autour du marketing, du numérique, de l’IA et d’autres sujets qui nourrissent la curiosité.
          </p>
          <a href="/blog" class="read-more">Lire la suite...</a>
        </div>
      </article>

      <article class="post-card">
        <div class="card-visual visual-orange">
          <img src="/images/carnet-bord_logo.png" alt="" class="card-logo" />
        </div>
        <div class="card-body">
          <p class="card-meta">PROJETS • À VENIR</p>
          <h2>Travaux et expérimentations</h2>
          <p>
            Une place pour montrer certaines réalisations, pistes de travail et expérimentations personnelles.
          </p>
          <a href="/about" class="read-more">Lire la suite...</a>
        </div>
      </article>

      <article class="post-card">
        <div class="card-visual visual-purple">
          <img src="/images/carnet-bord_logo.png" alt="" class="card-logo" />
        </div>
        <div class="card-body">
          <p class="card-meta">CARNETS • À VENIR</p>
          <h2>Réflexions et observations</h2>
          <p>
            Des notes plus spontanées, des idées en construction et quelques fragments de parcours.
          </p>
          <a href="/blog" class="read-more">Lire la suite...</a>
        </div>
      </article>

      <article class="post-card">
        <div class="card-visual visual-red">
          <img src="/images/carnet-bord_logo.png" alt="" class="card-logo" />
        </div>
        <div class="card-body">
          <p class="card-meta">SITE • EN COURS</p>
          <h2>Une base en train de se construire</h2>
          <p>
            Le site évolue progressivement : structure, identité visuelle et premiers contenus sont en préparation.
          </p>
          <a href="/" class="read-more">Lire la suite...</a>
        </div>
      </article>
    </div>
  </section>
</MainLayout>

<style>
  .home-grid {
    display: grid;
    gap: 2rem;
  }

  .featured-card {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    overflow: hidden;
  }

  .featured-content {
    padding: 2rem 2rem 2.25rem;
  }

  .meta,
  .card-meta {
    margin: 0 0 1rem;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #4d8df7;
  }

  h1 {
    margin: 0 0 1rem;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.15;
    color: #2f3438;
  }

  .excerpt {
    max-width: 58ch;
    color: #5b636b;
    font-size: 1.05rem;
  }

  .featured-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 320px;
    background: #8899d8;
    padding: 2rem;
  }

  .featured-logo {
    width: min(180px, 55%);
    height: auto;
    object-fit: contain;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .post-card {
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    overflow: hidden;
  }

  .card-visual {
    height: 190px;
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    padding: 1rem;
  }

  .visual-blue {
    background: #6f79c8;
  }

  .visual-orange {
    background: #f2a322;
  }

  .visual-purple {
    background: #6c33e6;
  }

  .visual-red {
    background: #c70000;
  }

  .card-logo {
    width: 88px;
    height: auto;
    object-fit: contain;
  }

  .card-body {
    padding: 1.25rem 1.25rem 1.5rem;
  }

  h2 {
    margin: 0 0 0.75rem;
    font-size: 1.9rem;
    line-height: 1.2;
    color: #2f3438;
  }

  .post-card h2 {
    font-size: 1.8rem;
  }

  .card-body p {
    color: #5b636b;
  }

  .read-more {
    display: inline-block;
    margin-top: 0.5rem;
    color: #4d8df7;
    text-decoration: none;
    font-weight: 500;
  }

  .read-more:hover {
    text-decoration: underline;
  }

  @media (max-width: 900px) {
    .featured-card {
      grid-template-columns: 1fr;
    }

    .featured-visual {
      min-height: 240px;
    }
  }

  @media (max-width: 700px) {
    .cards-grid {
      grid-template-columns: 1fr;
    }

    .featured-content,
    .card-body {
      padding: 1.25rem;
    }

    .featured-visual {
      padding: 1.5rem;
    }
  }
</style>