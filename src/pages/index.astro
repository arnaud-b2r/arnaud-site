---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
<section class="coming-soon">
  <div class="content">
    <p class="eyebrow">Arnaud Borderiou</p>

    <img src="/images/carnet-bord_logo.png" alt="Carnet de bord" class="logo" />

    <h1>Site en cours de développement</h1>

    <p class="subtitle">
      Une nouvelle version du site arrive bientôt, patience, patience.
    </p>

    <p class="intro">
      Merci de votre visite. Ce site est actuellement en construction.
    </p>
  </div>
</section>
</MainLayout>

<style>
  .coming-soon {
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 2rem;

  /* 🎨 fond moderne */
  background:
    radial-gradient(circle at top left, rgba(255, 191, 163, 0.4), transparent 30%),
    radial-gradient(circle at bottom right, rgba(200, 182, 255, 0.4), transparent 35%),
    linear-gradient(135deg, #4f7cff 0%, #6a7cff 50%, #c8b6ff 100%);

  color: white;
}

.content {
  text-align: center;
  max-width: 700px;
  width: 100%;
  padding: clamp(1.5rem, 4vw, 3rem);
  margin: 0 1rem;

  border-radius: 24px;

  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.logo {
  width: 70px;
  height: auto;
  margin-bottom: 1.5rem;
  object-fit: contain;
}

  .eyebrow {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.7;
    margin-bottom: 1rem;
  }

h1 {
  font-size: clamp(2rem, 6vw, 4.5rem);
  line-height: 1.1;
}

.subtitle {
  font-size: clamp(1rem, 2.5vw, 1.3rem);
}

.intro {
  font-size: clamp(0.9rem, 2.2vw, 1rem);
}


	.hero {
	padding-top: 4rem;
	}

	.hero img {
	transform: scale(1);
	transition: transform 0.3s ease;
	}

	.hero img:hover {
	transform: scale(1.05);
	}
	
</style>