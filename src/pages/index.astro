---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const recentPosts = posts.slice(0, 4);
---

<MainLayout>
  <section class="home-grid">

    <article class="featured-card">
      <div class="featured-content">
        <p class="meta">MON CARNET DE BORD</p>
        <h1>Bienvenue sur le carnet de bord</h1>
        <p class="excerpt">
          Bienvenue ici ! Ce site partage mes idées, mes découvertes et mes réflexions.
          Il évolue au fil du temps, au rythme de mes envies et de mes apprentissages.
          Merci de votre passage, et bonne lecture.
        </p>
      </div>
      <div class="featured-visual">
        <img src="/images/carnet-bord_logo.png" alt="Carnet de bord" class="featured-logo" />
      </div>
    </article>

    <div class="cards-grid">
      {recentPosts.map((post) => (
        <article class="post-card">
          <a href={`/blog/${post.id}/`} class="card-link">
            <div class="card-visual">
              {post.data.heroImage
                ? <img src={post.data.heroImage} alt={post.data.title} class="card-illustration" />
                : <div class="card-placeholder"></div>
              }
              {post.data.category && (
                <span class={`card-badge badge-${post.data.category.toLowerCase()}`}>
                  {post.data.category}
                </span>
              )}
            </div>
            <div class="card-body">
              <p class="card-date"><FormattedDate date={post.data.pubDate} /></p>
              <h2>{post.data.title}</h2>
              {post.data.description && <p class="card-desc">{post.data.description}</p>}
              <span class="read-more-link">Lire la suite →</span>
            </div>
          </a>
        </article>
      ))}
    </div>

  </section>
</MainLayout>

<style>
  .home-grid {
    display: grid;
    gap: 2rem;
  }

  .featured-card {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 14px;
    overflow: hidden;
  }

  .featured-content {
    padding: 2rem 2rem 2.25rem;
  }

  .meta {
    margin: 0 0 1rem;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #e8572a;
    font-family: 'Source Sans 3', system-ui, sans-serif;
  }

  .featured-content h1 {
    margin: 0 0 1rem;
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    line-height: 1.15;
    color: #1a3a4a;
    font-family: 'Source Sans 3', system-ui, sans-serif;
    font-weight: 500;
  }

  .excerpt {
    max-width: 58ch;
    color: #5b636b;
    font-size: 1rem;
    line-height: 1.65;
    margin: 0;
  }

  .featured-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 280px;
    padding: 2rem;
    background: #f5f0e8;
  }

  .featured-logo {
    width: min(180px, 55%);
    height: auto;
    object-fit: contain;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .post-card {
    background: #ffffff;
    border: 0.5px solid #ddd5c5;
    border-radius: 14px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .post-card:hover {
    border-color: #e8572a;
  }

  .card-link {
    display: block;
    text-decoration: none !important;
    color: inherit !important;
  }

  .card-link:hover {
    text-decoration: none !important;
  }

  .card-visual {
    position: relative;
    height: 190px;
    overflow: hidden;
    background: #c9bfa8;
  }

  .card-illustration {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-placeholder {
    width: 100%;
    height: 100%;
    background: #c9bfa8;
  }

  .card-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    font-size: 0.7rem;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 4px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-family: 'Source Sans 3', system-ui, sans-serif;
  }

  .badge-tech      { background: #ddeaf2; color: #1a3a4a; }
  .badge-voyage    { background: #faeada; color: #8a4a1a; }
  .badge-marketing { background: #eaf2dd; color: #3a5a1a; }

  .card-body {
    padding: 1.1rem 1.25rem 1.4rem;
  }

  .card-date {
    font-size: 0.8rem;
    color: #a8997e;
    margin: 0 0 6px;
  }

  .card-body h2 {
    margin: 0 0 0.6rem;
    font-size: 1.05rem;
    line-height: 1.35;
    color: #1a3a4a;
    font-family: 'Source Sans 3', system-ui, sans-serif;
    font-weight: 500;
  }

  .card-desc {
    font-size: 0.875rem;
    color: #5a4e3c;
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .read-more-link {
    display: inline-block;
    margin-top: 10px;
    font-size: 0.85rem;
    color: #e8572a !important;
    font-weight: 500;
    text-decoration: none !important;
    border-bottom: none !important;
  }

  @media (max-width: 900px) {
    .featured-card {
      grid-template-columns: 1fr;
    }
    .featured-visual {
      min-height: 200px;
    }
  }

  @media (max-width: 700px) {
    .cards-grid {
      grid-template-columns: 1fr;
    }
    .featured-content,
    .card-body {
      padding: 1.25rem;
    }
  }
</style>
