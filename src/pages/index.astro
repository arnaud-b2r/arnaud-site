---
/**
 * index.astro — Homepage "Carnet de bord"
 * Light mode — juin 2026
 *
 * Structure :
 * 1. Hero : photo à gauche (pleine hauteur), texte à droite
 * 2. Section "Highlights" : 2 derniers articles côte à côte
 * 3. Lien "Découvrir tous les articles"
 *
 * Le mapping des catégories vers les sections Terrain/Curiosité/Échappées
 * est défini ici — les articles gardent leurs catégories granulaires
 * dans le frontmatter (.md), la homepage fait la correspondance.
 */
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

/*
  On récupère tous les articles, triés du plus récent au plus ancien.
  On n'affiche que les 2 plus récents sur la homepage — modifiable en
  changeant le chiffre dans .slice(0, 2).
*/
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const recentPosts = posts.slice(0, 2);

/*
  Mapping catégories → sections.
  Les clés correspondent aux valeurs du champ `category` dans le frontmatter.
  Les valeurs correspondent aux noms de sections affichés sur le site.
  Ajouter une catégorie ici si besoin.
*/
const categoryToSection: Record<string, string> = {
  marketing:       'Terrain',
  cybersécurité:   'Terrain',
  dématérialisation: 'Terrain',
  it:              'Terrain',
  ia:              'Curiosité',
  tech:            'Curiosité',
  voyage:          'Échappées',
  lecture:         'Échappées',
  culture:         'Échappées',
};

function getSection(category?: string): string {
  if (!category) return '';
  return categoryToSection[category.toLowerCase()] ?? category;
}
---

<MainLayout>

  <!-- ============================================================
       HERO
       Deux colonnes : photo pleine hauteur à gauche, texte à droite.
       La photo portrait occupe toute la colonne gauche — pas de cercle,
       pas de cadre, l'image est le fond de la colonne.
       ============================================================ -->
  <section class="hero-wrapper">
  <div class="hero">

    <!-- Colonne gauche : photo portrait -->
    <div class="hero-img">
      <img
        src="/images/portrait-arnaud.png"
        alt="Portrait d'Arnaud Borderiou"
        class="hero-photo"
      />
    </div>

    <!-- Colonne droite : texte -->
    <div class="hero-text">

      <p class="kicker">
        <span class="kicker-dot"></span>
        B2B Marketing · Angers
      </p>

      <h1 class="hero-title">
        Carnet<br>
        <em>de Bord</em><br>
        <span class="title-dim">et après.</span>
      </h1>

      <!--
        Bloc narratif avec filet terracotta à gauche.
        Ajuste ce texte selon ce que tu veux mettre en avant.
        C'est ta voix, pas un slogan — parle directement au lecteur.
      -->
      <p class="hero-narrative">
        Je m'appelle <strong>Arnaud Borderiou</strong>. Depuis 6 ans, je travaille le marketing en B2B — dématérialisation, IT, cybersécurité. Ce carnet, c'est ce qui déborde de LinkedIn : les lectures, les doutes, les virages que l'IA impose, et quelques détours par les chemins de randonnée.
      </p>

      <div class="hero-actions">
        <a href="/blog" class="btn-primary">Lire le journal</a>
        <a href="/about" class="btn-ghost">À propos →</a>
      </div>

    </div>
  </div>
  </section>

  <!-- ============================================================
       HIGHLIGHTS — 2 derniers articles
       ============================================================ -->
  <section class="highlights">

    <div class="highlights-header">
      <h2 class="highlights-title">Highlights</h2>
      <a href="/blog" class="browse-btn">Tous les articles →</a>
    </div>

    <!--
      Grille de 2 cards côte à côte.
      Chaque card : image pleine largeur, puis titre + flèche,
      date, excerpt, badge section.
    -->
    <div class="cards-grid">
      {recentPosts.map((post) => (
        <article class="card">
          <a href={`/blog/${post.id}/`} class="card-link" aria-label={`Lire : ${post.data.title}`}>

            <!-- Image de couverture -->
            <div class="card-img">
              {post.data.heroImage
                ? <img src={post.data.heroImage} alt={post.data.title} class="card-photo" />
                : <div class="card-placeholder" aria-hidden="true"></div>
              }
            </div>

            <!-- Corps de la card -->
            <div class="card-body">

              <!-- Titre + flèche diagonale -->
              <div class="card-title-row">
                <h3 class="card-title">{post.data.title}</h3>
                <span class="card-arrow" aria-hidden="true">↗</span>
              </div>

              <!-- Auteur · Date -->
              <p class="card-meta">
                Arnaud Borderiou · <FormattedDate date={post.data.pubDate} />
              </p>

              <!-- Excerpt -->
              {post.data.description && (
                <p class="card-excerpt">{post.data.description}</p>
              )}

              <!-- Badge section (Terrain / Curiosité / Échappées) -->
              {post.data.category && (
                <span class="card-badge">
                  {getSection(post.data.category)}
                </span>
              )}

            </div>
          </a>
        </article>
      ))}
    </div>

    <!-- Lien discret pour voir tous les articles -->
    <div class="discover">
      <a href="/blog" class="discover-link">Découvrir tous les articles →</a>
    </div>

  </section>

</MainLayout>

<style>
/*
  Styles scopés à index.astro.
  Utilisent les variables de global.css.
*/

/* ============================================================
   HERO
   ============================================================ */

.hero-wrapper {
  border-bottom: 0.5px solid var(--color-border);
}

.hero {
  display: grid;
  /*
    Deux colonnes égales dans un conteneur centré.
    Même max-width que les Highlights pour aligner les sections.
  */
  grid-template-columns: 1fr 1fr;
  max-width: var(--content-width);
  margin: 0 auto;
}

/* Colonne gauche : photo — suit la hauteur naturelle de la colonne droite */
.hero-img {
  overflow: hidden;
  background: var(--color-bg-subtle);
  position: relative;
}

.hero-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  /*
    object-position : centre haut pour que le visage soit toujours visible.
    Ajuste si la composition de ta photo le nécessite.
  */
  object-position: center top;
  display: block;
}

/* Colonne droite : texte */
.hero-text {
  padding: 40px 48px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  border-left: 0.5px solid var(--color-border);
}

.kicker {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: 400;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-text-faint);
  margin-bottom: 20px;
}

.kicker-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--color-accent);
  flex-shrink: 0;
}

.hero-title {
  font-family: var(--font-serif);
  font-size: clamp(2.4rem, 4vw, 3.2rem);
  font-weight: 900;
  line-height: 1.0;
  letter-spacing: -0.02em;
  color: var(--color-text);
  margin-bottom: 24px;
}

.hero-title em {
  color: var(--color-accent);
  font-style: italic;
}

.title-dim {
  color: var(--color-text-faint);
}

/*
  Bloc narratif : filet terracotta à gauche.
  Crée un signal visuel "prise de parole directe".
  strong : passe de muted à text pour les mots importants.
*/
.hero-narrative {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: 300;
  line-height: var(--leading-normal);
  color: var(--color-text-muted);
  max-width: 58ch;
  margin-bottom: 36px;
  border-left: 1.5px solid rgba(232, 113, 74, 0.35);
  padding-left: 14px;
}

.hero-narrative strong {
  color: var(--color-text);
  font-weight: 400;
}

.hero-actions {
  display: flex;
  align-items: center;
  gap: 20px;
}

/*
  btn-primary : fond sombre, texte clair, coins arrondis pill.
  Inspiré du style Krung Thep — plus doux que le carré terracotta précédent.
*/
.btn-primary {
  display: inline-block;
  background: var(--color-text);
  color: var(--color-bg);
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 12px 24px;
  border-radius: var(--radius-pill);
  text-decoration: none;
  transition: opacity 0.15s ease;
}

.btn-primary:hover {
  opacity: 0.8;
  text-decoration: none;
  color: var(--color-bg);
}

.btn-ghost {
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: 400;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-text-faint);
  text-decoration: none;
  transition: color 0.15s ease;
}

.btn-ghost:hover {
  color: var(--color-text);
  text-decoration: none;
}

/* ============================================================
   HIGHLIGHTS
   ============================================================ */

.highlights {
  max-width: var(--content-width);
  margin: 0 auto;
  padding-bottom: 64px;
}

.highlights-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 48px var(--content-padding) 28px;
}

.highlights-title {
  font-family: var(--font-serif);
  font-size: clamp(1.5rem, 2.5vw, 1.75rem);
  font-weight: 700;
  color: var(--color-text);
}

/*
  browse-btn : bouton pill avec bordure fine.
  Même style que dans le template Krung Thep.
*/
.browse-btn {
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-text);
  border: 1px solid var(--color-border);
  padding: 9px 20px;
  border-radius: var(--radius-pill);
  text-decoration: none;
  transition: border-color 0.15s ease, color 0.15s ease;
}

.browse-btn:hover {
  border-color: var(--color-text);
  color: var(--color-text);
  text-decoration: none;
}

/* Grille 2 colonnes */
.cards-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  padding: 0 var(--content-padding);
}

/* Card */
.card {
  background: var(--color-bg-raised);
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 0.5px solid var(--color-border);
  transition: box-shadow 0.2s ease;
}

.card:hover {
  box-shadow: 0 4px 24px rgba(26, 26, 24, 0.07);
}

.card-link {
  display: block;
  text-decoration: none;
  color: inherit;
  height: 100%;
}

.card-link:hover {
  text-decoration: none;
}

/* Image de la card */
.card-img {
  width: 100%;
  height: 220px;
  overflow: hidden;
  background: var(--color-bg-subtle);
}

.card-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.3s ease;
}

.card:hover .card-photo {
  transform: scale(1.02);
}

.card-placeholder {
  width: 100%;
  height: 100%;
  background: var(--color-bg-subtle);
}

/* Corps de la card */
.card-body {
  padding: 20px 22px 22px;
}

/*
  Titre + flèche ↗ sur la même ligne.
  La flèche signale le lien externe / la navigation — inspiré de Krung Thep.
*/
.card-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 10px;
}

.card-title {
  font-family: var(--font-serif);
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--color-text);
  line-height: var(--leading-snug);
}

.card-arrow {
  font-size: 16px;
  color: var(--color-text-faint);
  flex-shrink: 0;
  margin-top: 2px;
  transition: color 0.15s ease;
}

.card:hover .card-arrow {
  color: var(--color-text);
}

.card-meta {
  font-family: var(--font-sans);
  font-size: 11px;
  font-weight: 300;
  color: var(--color-text-faint);
  margin-bottom: 12px;
  letter-spacing: 0.02em;
}

.card-excerpt {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: 300;
  line-height: var(--leading-normal);
  color: var(--color-text-muted);
  margin-bottom: 16px;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/*
  Badge section : pill avec bordure fine, texte discret.
  Affiche Terrain / Curiosité / Échappées selon le mapping défini en haut.
*/
.card-badge {
  display: inline-block;
  font-family: var(--font-sans);
  font-size: 10px;
  font-weight: 400;
  letter-spacing: 0.06em;
  color: var(--color-text-muted);
  border: 1px solid var(--color-border);
  padding: 4px 12px;
  border-radius: var(--radius-pill);
}

/* Lien "Découvrir tous les articles" */
.discover {
  text-align: center;
  padding: 36px var(--content-padding) 0;
}

.discover-link {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: 400;
  color: var(--color-text-muted);
  text-decoration: underline;
  text-underline-offset: 3px;
  transition: color 0.15s ease;
}

.discover-link:hover {
  color: var(--color-text);
}

/* ============================================================
   RESPONSIVE
   ============================================================ */

/* Tablette */
@media (max-width: 900px) {
  .hero {
    grid-template-columns: 1fr;
    min-height: auto;
  }

  .hero-img {
    height: 300px;
  }

  .hero-text {
    padding: 40px var(--content-padding);
    border-left: none;
    border-top: 0.5px solid var(--color-border);
  }
}

/* Mobile */
@media (max-width: 640px) {
  .cards-grid {
    grid-template-columns: 1fr;
  }

  .highlights-header {
    padding-top: 36px;
  }
}

@media (max-width: 480px) {
  .hero-title {
    font-size: 2.2rem;
  }

  .hero-text {
    padding: 32px var(--content-padding);
  }
}
</style>