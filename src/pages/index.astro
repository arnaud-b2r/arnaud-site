---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
  <section class="coming-soon">
    <p class="eyebrow">Arnaud Borderiou</p>
    <img src="/images/carnet-bord_logo.png" alt="Carnet de bord" class="logo" />
    <h1>Site en cours de développement</h1>
    <p class="subtitle">
      Une nouvelle version du site arrive bientôt, patience, patience.
    </p>
    <p class="intro">
      Merci de votre visite. Ce site est actuellement en construction.
    </p>
  </section>
</MainLayout>

<style>
  .coming-soon {
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 2rem;
  }

  .eyebrow {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.7;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 4rem);
    margin-bottom: 1rem;
  }

  .subtitle {
    font-size: 1.2rem;
    margin-bottom: 1rem;
    max-width: 600px;
  }

  .intro {
    max-width: 700px;
    opacity: 0.8;
  }
</style>