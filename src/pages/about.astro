---
/**
 * about.astro — Page À propos
 * Light mode — juin 2026
 * Même structure que la homepage :
 * - Hero : photo gauche, texte droite
 * - Sections de contenu en dessous
 */
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="À propos — Carnet de bord">

  <!-- ============================================================
       HERO — même structure que la homepage
       ============================================================ -->
  <section class="hero-wrapper">
    <div class="hero">

      <div class="hero-img">
        <img
          src="/images/portrait-arnaud.png"
          alt="Portrait d'Arnaud Borderiou"
          class="hero-photo"
        />
      </div>

      <div class="hero-text">
        <p class="kicker">
          <span class="kicker-dot"></span>
          B2B Marketing · Angers
        </p>
        <h1 class="hero-title">Arnaud<br><em>Borderiou</em></h1>
        <p class="hero-sub">
          Marketeur B2B depuis 6 ans. Curieux de nature, attentif aux transformations que l'IA impose à nos métiers. Ce site est mon espace pour penser à voix haute.
        </p>
      </div>

    </div>
  </section>

  <!-- ============================================================
       CONTENU — sections biographiques
       ============================================================ -->
  <div class="about-content">

    <!-- Section : Qui je suis -->
    <div class="about-section">
      <div class="about-label">
        <span class="label-text">Qui je suis</span>
      </div>
      <div class="about-body">
        <p>
          Je travaille en marketing B2B depuis 2018, principalement dans des secteurs techniques : dématérialisation, IT, téléphonie, cybersécurité. Mon quotidien, c'est construire des stratégies de contenu, comprendre les cycles de vente longs, et trouver les bons mots pour des sujets que peu de gens trouvent naturellement sexy.
        </p>
        <p>
          Ce qui m'intéresse dans ce métier, c'est la tension entre la rigueur technique et la capacité à raconter des histoires. Un bon contenu B2B, c'est un contenu qui respecte l'intelligence du lecteur tout en lui donnant envie de continuer.
        </p>
      </div>
    </div>

    <!-- Section : Pourquoi ce carnet -->
    <div class="about-section">
      <div class="about-label">
        <span class="label-text">Pourquoi ce carnet</span>
      </div>
      <div class="about-body">
        <p>
          LinkedIn est utile, mais c'est une scène. On y joue un rôle, on y polit les angles, on y évite les doutes. Ce carnet, c'est autre chose : un endroit pour noter ce que j'apprends, ce qui me questionne, ce qui me plaît.
        </p>
        <p>
          Il couvre mon univers professionnel — marketing, tech, IA — mais aussi ce qui déborde : les lectures, les voyages, les randonnées. Ce n'est pas un portfolio. C'est un journal de bord.
        </p>
      </div>
    </div>

    <!-- Section : Ce que je suis en train d'explorer -->
    <div class="about-section">
      <div class="about-label">
        <span class="label-text">En ce moment</span>
      </div>
      <div class="about-body">
        <p>
          Je suis de près les usages concrets de l'IA dans les équipes marketing — pas les promesses des vendeurs de formation, mais ce que les gens utilisent vraiment, tous les jours. Je construis aussi ce site pas à pas, en apprenant Astro.js en chemin.
        </p>
        <p>
          Côté lectures, j'alterne entre des ouvrages sur la stratégie, des essais sur la technologie et quelques romans qui n'ont rien à voir avec tout ça — ce qui est peut-être le meilleur moyen de garder les idées fraîches.
        </p>
      </div>
    </div>

    <!-- Section : Contact -->
    <div class="about-section about-section--last">
      <div class="about-label">
        <span class="label-text">Contact</span>
      </div>
      <div class="about-body">
        <p>
          La meilleure façon de me joindre reste LinkedIn. Je lis tous les messages, je réponds à la plupart.
        </p>
        <div class="about-links">
          <a href="https://www.linkedin.com/in/arnaud-borderiou/" target="_blank" rel="noopener noreferrer" class="about-link">
            LinkedIn →
          </a>
          <a href="/rss.xml" class="about-link about-link--subtle">
            RSS →
          </a>
        </div>
      </div>
    </div>

  </div>

</MainLayout>

<style>
/* ============================================================
   HERO — identique à la homepage
   ============================================================ */

.hero-wrapper {
  border-bottom: 0.5px solid var(--color-border);
}

.hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  max-width: var(--content-width);
  margin: 0 auto;
}

.hero-img {
  overflow: hidden;
  background: var(--color-bg-subtle);
  position: relative;
}

.hero-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.hero-text {
  padding: 40px 48px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  border-left: 0.5px solid var(--color-border);
}

.kicker {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: 400;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-text-faint);
  margin-bottom: 20px;
}

.kicker-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--color-accent);
  flex-shrink: 0;
}

.hero-title {
  font-family: var(--font-serif);
  font-size: clamp(2.4rem, 4vw, 3.2rem);
  font-weight: 900;
  line-height: 1.0;
  letter-spacing: -0.02em;
  color: var(--color-text);
  margin-bottom: 20px;
}

.hero-title em {
  color: var(--color-accent);
  font-style: italic;
}

.hero-sub {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: 300;
  line-height: var(--leading-normal);
  color: var(--color-text-muted);
  max-width: 52ch;
  border-left: 1.5px solid rgba(232, 113, 74, 0.35);
  padding-left: 14px;
}

/* ============================================================
   CONTENU
   ============================================================ */

.about-content {
  max-width: var(--content-width);
  margin: 0 auto;
}

/*
  Chaque section : label à gauche (1/3), contenu à droite (2/3).
  Séparées par une bordure fine en bas.
  Même logique de grille que les magazines éditoriaux.
*/
.about-section {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 0;
  border-bottom: 0.5px solid var(--color-border);
}

.about-section--last {
  border-bottom: none;
}

.about-label {
  padding: 48px var(--content-padding) 48px 40px;
  border-right: 0.5px solid var(--color-border);
  display: flex;
  align-items: flex-start;
}

.label-text {
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-text-faint);
  /* Tiret terracotta avant le label */
  display: flex;
  align-items: center;
  gap: 10px;
}

.label-text::before {
  content: '';
  display: inline-block;
  width: 16px;
  height: 1px;
  background: var(--color-accent);
  flex-shrink: 0;
}

.about-body {
  padding: 48px 48px 48px 48px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.about-body p {
  font-family: var(--font-sans);
  font-size: var(--text-base);
  font-weight: 300;
  line-height: var(--leading-normal);
  color: var(--color-text-muted);
  max-width: 66ch;
}

/* Liens de contact */
.about-links {
  display: flex;
  align-items: center;
  gap: 24px;
  margin-top: 8px;
}

.about-link {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: 500;
  letter-spacing: 0.04em;
  color: var(--color-text);
  text-decoration: none;
  border-bottom: 1px solid var(--color-text);
  padding-bottom: 2px;
  transition: color 0.15s ease, border-color 0.15s ease;
}

.about-link:hover {
  color: var(--color-accent);
  border-color: var(--color-accent);
  text-decoration: none;
}

.about-link--subtle {
  color: var(--color-text-faint);
  border-color: var(--color-border);
  font-weight: 400;
}

/* ============================================================
   RESPONSIVE
   ============================================================ */

@media (max-width: 900px) {
  .hero {
    grid-template-columns: 1fr;
  }

  .hero-img {
    height: 280px;
  }

  .hero-text {
    padding: 40px var(--content-padding);
    border-left: none;
    border-top: 0.5px solid var(--color-border);
  }

  .about-section {
    grid-template-columns: 1fr;
  }

  .about-label {
    padding: 32px var(--content-padding) 16px;
    border-right: none;
    border-bottom: 0.5px solid var(--color-border);
  }

  .about-body {
    padding: 24px var(--content-padding) 40px;
  }
}
</style>