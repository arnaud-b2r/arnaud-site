---
/**
 * about.astro — Page À propos
 * Design dark mode harmonisé avec la homepage et la page articles.
 * Structure : hero identité + sections prose centrées.
 */
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="À propos — Arnaud Borderiou"
  description="Responsable marketing B2B, je transforme des sujets complexes en contenus utiles. Découvrez mon parcours, mes compétences et ce qui m'anime."
>

  <!-- ============================================================
       HERO IDENTITÉ
       Même kicker + grand titre que les autres pages.
       Photo/logo à droite en miroir du hero homepage.
       ============================================================ -->
  <section class="about-hero">
    <div class="about-hero-inner">

      <div class="about-hero-left">
        <p class="kicker">
          <span class="kicker-dot"></span>
          À propos
        </p>
        <h1>Arnaud <em>Borderiou</em></h1>
        <p class="tagline">
          Responsable marketing B2B — dématérialisation, IT, téléphonie, cybersécurité
        </p>
        <a
          href="https://www.linkedin.com/in/arnaudborderiou/"
          class="linkedin-btn"
          target="_blank"
          rel="noopener noreferrer"
        >
          Voir mon profil LinkedIn →
        </a>
      </div>

      <div class="about-hero-right">
        <div class="photo-wrap">
          <img
            src="/images/carnet-bord_logo.png"
            alt="Arnaud Borderiou"
            class="profile-img"
          />
        </div>
      </div>

    </div>
  </section>

  <!-- ============================================================
       CONTENU PROSE
       Trois sections + signature, largeur contrainte pour la lisibilité.
       ============================================================ -->
  <div class="about-content">

    <section class="about-section">
      <h2>Ce que je fais</h2>
      <p>
        Je travaille dans le marketing B2B depuis assez longtemps pour avoir vu l'essor des réseaux sociaux,
        la montée de la data et l'irruption de l'IA — trois révolutions qui ont chacune redistribué les cartes du métier.
      </p>
      <p>
        Aujourd'hui, j'exerce dans une entreprise spécialisée dans les solutions aux professionnels :
        dématérialisation des documents, informatique d'entreprise, téléphonie et cybersécurité.
        Mon quotidien, c'est aider des équipes commerciales à mieux vendre, produire des contenus utiles,
        et penser des stratégies adaptées à des acheteurs professionnels qui n'ont ni le temps ni la patience
        d'être mal adressés.
      </p>
      <p>
        Ce qui me distingue, c'est ma capacité à rendre lisibles des sujets techniques et à construire
        des contenus qui servent à nos commerciaux plutôt que de rester dans les tiroirs. Et ce n'est pas facile.
      </p>
    </section>

    <section class="about-section">
      <h2>Pourquoi ce site</h2>
      <p>
        Avec ce site j'essaie de croiser les regards, suivre l'actualité tech et IA avec ma vision,
        et partager ce qui me semble réellement intéressant.
      </p>
      <p>
        Vous trouverez ici des réflexions professionnelles, mais aussi et surtout des détours plus personnels —
        voyages, lectures et mes autres passions.
      </p>
    </section>

    <section class="about-section">
      <h2>En dehors du bureau</h2>
      <p>
        Je profite de la vie : je lis beaucoup — des romans (Murakami, Ken Follett, la série Agatha Raisin
        et beaucoup d'autres choses), des BD franco-belges et des mangas, deux cultures graphiques tellement passionnantes.
        Je marche, je randonne, je voyage autant que possible — le Japon, l'Angleterre, la Scandinavie figurent
        parmi mes dernières destinations. Et je suis de près l'actualité tech, pas comme un geek,
        mais comme quelqu'un qui veut comprendre ce qui change vraiment dans nos façons de travailler.
      </p>
    </section>

    <p class="signature">— Arnaud Borderiou, Angers</p>

  </div>

</MainLayout>

<style>
/* ============================================================
   HERO
   ============================================================ */

.about-hero {
  border-bottom: 0.5px solid var(--color-border);
}

.about-hero-inner {
  max-width: var(--content-width);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 340px;
  min-height: 320px;
}

/* Colonne gauche */
.about-hero-left {
  padding: 52px 48px 52px 40px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16px;
  border-right: 0.5px solid var(--color-border);
}

.kicker {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: 400;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-text-faint);
  margin: 0;
}

.kicker-dot {
  display: inline-block;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--color-accent);
  flex-shrink: 0;
}

.about-hero-left h1 {
  font-family: var(--font-serif);
  font-size: clamp(2.2rem, 4vw, 3.5rem);
  font-weight: 900;
  line-height: 1.0;
  letter-spacing: -0.02em;
  color: var(--color-text);
  margin: 0;
}

.about-hero-left h1 em {
  color: var(--color-accent);
  font-style: italic;
}

.tagline {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: 300;
  line-height: var(--leading-normal);
  color: var(--color-text-muted);
  margin: 0;
  max-width: 44ch;
}

.linkedin-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-bg);
  background: var(--color-accent);
  padding: 11px 22px;
  border-radius: var(--radius-sm);
  text-decoration: none;
  width: fit-content;
  transition: opacity 0.15s ease;
}

.linkedin-btn:hover {
  opacity: 0.88;
  text-decoration: none;
}

/* Colonne droite — photo */
.about-hero-right {
  background: var(--color-bg-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40px;
}

.photo-wrap {
  width: 140px;
  height: 140px;
  border-radius: 50%;
  background: #1A3A4A;
  border: 0.5px solid var(--color-border-mid);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ============================================================
   CONTENU PROSE
   Largeur contrainte pour la lisibilité (--prose-width = 720px).
   Centré dans la page avec padding latéral.
   ============================================================ */

.about-content {
  max-width: var(--prose-width);
  margin: 0 auto;
  padding: 56px 40px 80px;
}

.about-section {
  margin-bottom: 48px;
  padding-bottom: 48px;
  border-bottom: 0.5px solid var(--color-border);
}

.about-section:last-of-type {
  border-bottom: none;
  margin-bottom: 32px;
  padding-bottom: 0;
}

.about-section h2 {
  font-family: var(--font-serif);
  font-size: var(--text-xl);
  font-weight: 700;
  color: var(--color-text);
  margin: 0 0 20px;
  line-height: var(--leading-tight);
}

/*
  Tiret accent avant chaque titre de section —
  cohérent avec le section-label de la homepage.
*/
.about-section h2::before {
  content: '';
  display: inline-block;
  width: 18px;
  height: 1.5px;
  background: var(--color-accent);
  vertical-align: middle;
  margin-right: 10px;
  margin-bottom: 2px;
}

.about-section p {
  font-family: var(--font-sans);
  font-size: var(--text-base);
  font-weight: 300;
  line-height: var(--leading-loose);
  color: var(--color-text-muted);
  margin: 0 0 16px;
}

.about-section p:last-child {
  margin-bottom: 0;
}

.signature {
  font-family: var(--font-serif);
  font-style: italic;
  font-size: var(--text-sm);
  color: var(--color-text-faint);
  margin: 0;
}

/* ============================================================
   RESPONSIVE
   ============================================================ */

@media (max-width: 768px) {
  .about-hero-inner {
    grid-template-columns: 1fr;
    min-height: auto;
  }

  .about-hero-left {
    padding: 40px 24px;
    border-right: none;
    border-bottom: 0.5px solid var(--color-border);
  }

  /* Photo masquée sur mobile — le texte suffit */
  .about-hero-right {
    display: none;
  }

  .about-content {
    padding: 40px 24px 60px;
  }
}

@media (max-width: 480px) {
  .about-hero-left h1 {
    font-size: 2rem;
  }

  .about-content {
    padding: 32px 20px 48px;
  }
}
</style>