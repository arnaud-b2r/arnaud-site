---
/**
 * blog/index.astro — Page principale des articles
 * Light mode — juin 2026
 *
 * Structure :
 * - Article featured : photo gauche + titre/extrait droite
 * - Grille 2 colonnes pour les articles suivants
 * - Filtre par catégorie via query param ?categorie=terrain|curiosite|echappees
 *
 * Mapping catégories → sections (identique à index.astro) :
 * terrain    → marketing, cybersécurité, dématérialisation, it
 * curiosite  → ia, tech
 * echappees  → voyage, lecture, culture
 */
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const categoryToSection: Record<string, string> = {
  marketing:         'Terrain',
  cybersécurité:     'Terrain',
  dématérialisation: 'Terrain',
  it:                'Terrain',
  ia:                'Curiosité',
  tech:              'Curiosité',
  voyage:            'Échappées',
  lecture:           'Échappées',
  culture:           'Échappées',
};

const sectionToCategories: Record<string, string[]> = {
  terrain:    ['marketing', 'cybersécurité', 'dématérialisation', 'it'],
  curiosite:  ['ia', 'tech'],
  echappees:  ['voyage', 'lecture', 'culture'],
};

function getSection(category?: string): string {
  if (!category) return '';
  return categoryToSection[category.toLowerCase()] ?? category;
}

/*
  Récupération du filtre catégorie depuis l'URL (?categorie=terrain).
  Si aucun filtre, on affiche tous les articles.
*/
const filterParam = Astro.url.searchParams.get('categorie')?.toLowerCase() ?? '';
const validFilters = ['terrain', 'curiosite', 'echappees'];
const activeFilter = validFilters.includes(filterParam) ? filterParam : '';

const sectionLabels: Record<string, string> = {
  terrain:   'Terrain',
  curiosite: 'Curiosité',
  echappees: 'Échappées',
};
const pageTitle = activeFilter ? sectionLabels[activeFilter] : 'Tous les articles';

/* Récupération et tri des articles */
let allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

/* Filtrage si catégorie active */
if (activeFilter) {
  const allowedCats = sectionToCategories[activeFilter] ?? [];
  allPosts = allPosts.filter(p =>
    allowedCats.includes(p.data.category?.toLowerCase() ?? '')
  );
}

const featuredPost = allPosts[0];
const otherPosts = allPosts.slice(1);
---

<MainLayout title={`${pageTitle} — Carnet de bord`}>

  <!-- ============================================================
       EN-TÊTE DE PAGE
       ============================================================ -->
  <div class="page-header">
    <div class="page-header-inner">
      <h1 class="page-title">{pageTitle}</h1>

      <!-- Filtres de navigation entre sections -->
      <nav class="filter-nav" aria-label="Filtrer par section">
        <a href="/blog" class={!activeFilter ? 'active' : ''}>Tout</a>
        <a href="/blog/terrain" class={activeFilter === 'terrain' ? 'active' : ''}>Terrain</a>
        <a href="/blog/curiosite" class={activeFilter === 'curiosite' ? 'active' : ''}>Curiosité</a>
        <a href="/blog/echappees" class={activeFilter === 'echappees' ? 'active' : ''}>Échappées</a>
      </nav>
    </div>
  </div>

  <!-- ============================================================
       ARTICLE FEATURED — photo gauche, texte droite
       Même structure que le hero de la homepage.
       ============================================================ -->
  {featuredPost && (
    <section class="featured-wrapper">
      <a href={`/blog/${featuredPost.id}/`} class="featured" aria-label={`Lire : ${featuredPost.data.title}`}>

        <!-- Photo -->
        <div class="featured-img">
          {featuredPost.data.heroImage
            ? <img src={featuredPost.data.heroImage} alt={featuredPost.data.title} class="featured-photo" />
            : <div class="featured-placeholder"></div>
          }
        </div>

        <!-- Texte -->
        <div class="featured-text">
          <p class="featured-section">
            <span class="section-dot"></span>
            {featuredPost.data.subcategory ?? featuredPost.data.category}
          </p>
          <h2 class="featured-title">{featuredPost.data.title}</h2>
          <p class="featured-meta">
            Arnaud Borderiou · <FormattedDate date={featuredPost.data.pubDate} />
          </p>
          {featuredPost.data.description && (
            <p class="featured-excerpt">{featuredPost.data.description}</p>
          )}
          <span class="featured-cta">Lire l'article →</span>
        </div>

      </a>
    </section>
  )}

  <!-- ============================================================
       GRILLE — autres articles
       ============================================================ -->
  {otherPosts.length > 0 && (
    <section class="articles-section">
      <div class="articles-inner">
        <div class="cards-grid">
          {otherPosts.map((post) => (
            <article class="card">
              <a href={`/blog/${post.id}/`} class="card-link" aria-label={`Lire : ${post.data.title}`}>

                <div class="card-img">
                  {post.data.heroImage
                    ? <img src={post.data.heroImage} alt={post.data.title} class="card-photo" />
                    : <div class="card-placeholder"></div>
                  }
                </div>

                <div class="card-body">
                  <div class="card-title-row">
                    <h3 class="card-title">{post.data.title}</h3>
                    <span class="card-arrow" aria-hidden="true">↗</span>
                  </div>
                  <p class="card-meta">
                    Arnaud Borderiou · <FormattedDate date={post.data.pubDate} />
                  </p>
                  {post.data.description && (
                    <p class="card-excerpt">{post.data.description}</p>
                  )}
                  {post.data.category && (
                    <span class="card-badge">{post.data.subcategory ?? post.data.category}</span>
                  )}
                </div>

              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {allPosts.length === 0 && (
    <div class="empty-state">
      <p>Aucun article dans cette section pour l'instant.</p>
      <a href="/blog">Voir tous les articles →</a>
    </div>
  )}

</MainLayout>

<style>
/* ============================================================
   EN-TÊTE DE PAGE
   ============================================================ */

.page-header {
  border-bottom: 0.5px solid var(--color-border);
}

.page-header-inner {
  max-width: var(--content-width);
  margin: 0 auto;
  padding: 48px var(--content-padding) 32px;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24px;
}

.page-title {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 900;
  color: var(--color-text);
  letter-spacing: -0.02em;
  line-height: 1;
}

/* Filtres de navigation */
.filter-nav {
  display: flex;
  align-items: center;
  gap: 4px;
}

.filter-nav a {
  font-family: var(--font-sans);
  font-size: 12px;
  font-weight: 400;
  letter-spacing: 0.04em;
  color: var(--color-text-muted);
  text-decoration: none;
  padding: 6px 14px;
  border-radius: var(--radius-pill);
  border: 1px solid transparent;
  transition: all 0.15s ease;
}

.filter-nav a:hover {
  color: var(--color-text);
  text-decoration: none;
}

.filter-nav a.active {
  color: var(--color-accent);
  border-color: rgba(232, 113, 74, 0.3);
  font-weight: 500;
}

/* ============================================================
   ARTICLE FEATURED
   ============================================================ */

.featured-wrapper {
  border-bottom: 0.5px solid var(--color-border);
}

.featured {
  display: grid;
  grid-template-columns: 1fr 1fr;
  max-width: var(--content-width);
  margin: 0 auto;
  text-decoration: none;
  color: inherit;
  transition: opacity 0.15s ease;
}

.featured:hover {
  opacity: 0.95;
  text-decoration: none;
}

.featured-img {
  overflow: hidden;
  background: var(--color-bg-subtle);
  min-height: 360px;
}

.featured-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  transition: transform 0.3s ease;
}

.featured:hover .featured-photo {
  transform: scale(1.02);
}

.featured-placeholder {
  width: 100%;
  height: 100%;
  min-height: 360px;
  background: var(--color-bg-subtle);
}

.featured-text {
  padding: 48px 56px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  border-left: 0.5px solid var(--color-border);
  gap: 16px;
}

.featured-section {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: 400;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-text-faint);
}

.section-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--color-accent);
  flex-shrink: 0;
}

.featured-title {
  font-family: var(--font-serif);
  font-size: clamp(1.5rem, 2.5vw, 2rem);
  font-weight: 900;
  line-height: var(--leading-snug);
  color: var(--color-text);
  letter-spacing: -0.01em;
}

.featured-meta {
  font-family: var(--font-sans);
  font-size: 11px;
  font-weight: 300;
  color: var(--color-text-faint);
  letter-spacing: 0.02em;
}

.featured-excerpt {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: 300;
  line-height: var(--leading-normal);
  color: var(--color-text-muted);
  max-width: 52ch;
  border-left: 1.5px solid rgba(232, 113, 74, 0.35);
  padding-left: 14px;
}

.featured-cta {
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: 500;
  letter-spacing: 0.06em;
  color: var(--color-accent);
  margin-top: 8px;
}

/* ============================================================
   GRILLE D'ARTICLES
   ============================================================ */

.articles-section {
  padding-bottom: 64px;
}

.articles-inner {
  max-width: var(--content-width);
  margin: 0 auto;
  padding: 48px var(--content-padding) 0;
}

.cards-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}

.card {
  background: var(--color-bg-raised);
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 0.5px solid var(--color-border);
  transition: box-shadow 0.2s ease;
}

.card:hover {
  box-shadow: 0 4px 24px rgba(26, 26, 24, 0.07);
}

.card-link {
  display: block;
  text-decoration: none;
  color: inherit;
}

.card-link:hover {
  text-decoration: none;
}

.card-img {
  width: 100%;
  height: 220px;
  overflow: hidden;
  background: var(--color-bg-subtle);
}

.card-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.3s ease;
}

.card:hover .card-photo {
  transform: scale(1.02);
}

.card-placeholder {
  width: 100%;
  height: 100%;
  background: var(--color-bg-subtle);
}

.card-body {
  padding: 20px 22px 22px;
}

.card-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 10px;
}

.card-title {
  font-family: var(--font-serif);
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--color-text);
  line-height: var(--leading-snug);
}

.card-arrow {
  font-size: 16px;
  color: var(--color-text-faint);
  flex-shrink: 0;
  margin-top: 2px;
  transition: color 0.15s ease;
}

.card:hover .card-arrow {
  color: var(--color-text);
}

.card-meta {
  font-family: var(--font-sans);
  font-size: 11px;
  font-weight: 300;
  color: var(--color-text-faint);
  margin-bottom: 12px;
}

.card-excerpt {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: 300;
  line-height: var(--leading-normal);
  color: var(--color-text-muted);
  margin-bottom: 16px;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-badge {
  display: inline-block;
  font-family: var(--font-sans);
  font-size: 10px;
  font-weight: 400;
  letter-spacing: 0.06em;
  color: var(--color-text-muted);
  border: 1px solid var(--color-border);
  padding: 4px 12px;
  border-radius: var(--radius-pill);
}

/* État vide */
.empty-state {
  max-width: var(--content-width);
  margin: 0 auto;
  padding: 80px var(--content-padding);
  text-align: center;
}

.empty-state p {
  font-family: var(--font-sans);
  font-size: var(--text-base);
  color: var(--color-text-faint);
  margin-bottom: 16px;
}

.empty-state a {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  color: var(--color-accent);
}

/* ============================================================
   RESPONSIVE
   ============================================================ */

@media (max-width: 900px) {
  .featured {
    grid-template-columns: 1fr;
  }

  .featured-img {
    min-height: 260px;
  }

  .featured-text {
    padding: 36px var(--content-padding);
    border-left: none;
    border-top: 0.5px solid var(--color-border);
  }

  .page-header-inner {
    flex-direction: column;
    align-items: flex-start;
  }
}

@media (max-width: 640px) {
  .cards-grid {
    grid-template-columns: 1fr;
  }

  .page-header-inner {
    padding-top: 36px;
  }
}
</style>