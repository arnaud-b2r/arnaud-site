---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featured = posts[0];
const rest = posts.slice(1);
---

<MainLayout title="Blog — Arnaud Borderiou">

	<section class="hero">
		<p class="eyebrow">Archives</p>
		<h1>Blog</h1>
		<p class="intro">
			Notes, réflexions et articles autour de la tech, du marketing et du numérique.
		</p>
	</section>

	<div class="filters">
		<button class="filter-btn active" data-filter="tous">Tous</button>
		<button class="filter-btn" data-filter="tech">Tech</button>
		<button class="filter-btn" data-filter="voyage">Voyage</button>
		<button class="filter-btn" data-filter="marketing">Marketing</button>
		<button class="filter-btn" data-filter="lecture">Lecture</button>
	</div>

	{featured && (
		<a
			href={`/blog/${featured.id}/`}
			class="featured-card"
			data-category={featured.data.category?.toLowerCase() ?? ''}
		>
			<div class="featured-img">
				{featured.data.heroImage
					? <img src={featured.data.heroImage} alt={featured.data.title} />
					: <div class="img-placeholder"></div>
				}
				{featured.data.category && (
					<span class={`badge badge-${featured.data.category.toLowerCase()}`}>
						{featured.data.category}
					</span>
				)}
			</div>
			<div class="featured-content">
				<span class="post-date"><FormattedDate date={featured.data.pubDate} /></span>
				<h2>{featured.data.title}</h2>
				{featured.data.description && <p>{featured.data.description}</p>}
				<span class="read-more">Lire la suite →</span>
			</div>
		</a>
	)}

	<ul class="post-grid">
		{rest.map((post) => (
			<li class="post-card" data-category={post.data.category?.toLowerCase() ?? ''}>
				<a href={`/blog/${post.id}/`}>
					<div class="card-img">
						{post.data.heroImage
							? <img src={post.data.heroImage} alt={post.data.title} />
							: <div class="img-placeholder"></div>
						}
						{post.data.category && (
							<span class={`badge badge-${post.data.category.toLowerCase()}`}>
								{post.data.category}
							</span>
						)}
					</div>
					<div class="card-body">
						<p class="post-date"><FormattedDate date={post.data.pubDate} /></p>
						<h3 class="post-title">{post.data.title}</h3>
						{post.data.description && (
							<p class="post-description">{post.data.description}</p>
						)}
						<span class="read-more">Lire la suite →</span>
					</div>
				</a>
			</li>
		))}
	</ul>

</MainLayout>

<style>
	.hero {
		padding: 2rem 0 1.5rem;
	}

	.eyebrow {
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #e8572a;
		margin: 0 0 0.5rem;
	}

	.hero h1 {
		font-size: 2.5rem;
		font-weight: 500;
		color: #1a3a4a;
		line-height: 1.1;
		margin: 0 0 0.5rem;
	}

	.intro {
		font-size: 1rem;
		color: #7a6b54;
		margin: 0;
	}

	.filters {
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
		margin: 1.5rem 0 2rem;
	}

	.filter-btn {
		padding: 6px 18px;
		border-radius: 20px;
		font-size: 0.85rem;
		border: 1px solid #c9bfa8;
		background: transparent;
		color: #4a3c28;
		cursor: pointer;
		transition: background 0.15s, color 0.15s, border-color 0.15s;
	}

	.filter-btn.active {
		background: #1a3a4a;
		color: #f5f0e8;
		border-color: #1a3a4a;
	}

	.featured-card {
		display: grid;
		grid-template-columns: 1fr 1fr;
		border-radius: 14px;
		overflow: hidden;
		background: white;
		border: 0.5px solid #ddd5c5;
		margin-bottom: 1.5rem;
		text-decoration: none;
		color: inherit;
		transition: border-color 0.2s;
	}

	.featured-card:hover {
		border-color: #e8572a;
	}

	.featured-img {
		position: relative;
		min-height: 280px;
		background: #1a3a4a;
		overflow: hidden;
	}

	.featured-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.img-placeholder {
		width: 100%;
		height: 100%;
		min-height: 280px;
		background: #1a3a4a;
	}

	.featured-content {
		padding: 2rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 12px;
	}

	.featured-content h2 {
		font-size: 1.4rem;
		font-weight: 500;
		color: #1a3a4a;
		line-height: 1.3;
		margin: 0;
	}

	.featured-content p {
		font-size: 0.9rem;
		color: #5a4e3c;
		line-height: 1.6;
		margin: 0;
	}

	.post-grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.25rem;
	}

	.post-card {
		border-radius: 14px;
		overflow: hidden;
		background: white;
		border: 0.5px solid #ddd5c5;
		transition: border-color 0.2s;
	}

	.post-card:hover {
		border-color: #e8572a;
	}

	.post-card a {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.card-img {
		position: relative;
		height: 180px;
		background: #c9bfa8;
		overflow: hidden;
	}

	.card-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.card-img .img-placeholder {
		width: 100%;
		height: 100%;
		min-height: 180px;
		background: #c9bfa8;
	}

	.card-body {
		padding: 1.1rem 1.25rem 1.25rem;
	}

	.post-date {
		font-size: 0.8rem;
		color: #a8997e;
		margin: 0 0 6px;
	}

	.post-title {
		font-size: 1.05rem;
		font-weight: 500;
		color: #1a3a4a;
		line-height: 1.35;
		margin: 0 0 8px;
	}

	.post-description {
		font-size: 0.875rem;
		color: #5a4e3c;
		line-height: 1.55;
		margin: 0;
	}

	.read-more {
		display: inline-block;
		margin-top: 10px;
		font-size: 0.85rem;
		color: #e8572a;
		font-weight: 500;
	}

	.badge {
		position: absolute;
		top: 12px;
		left: 12px;
		font-size: 0.7rem;
		font-weight: 500;
		padding: 3px 10px;
		border-radius: 4px;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.badge-tech {
		background: #ddeaf2;
		color: #1a3a4a;
	}

	.badge-voyage {
		background: #faeada;
		color: #8a4a1a;
	}

	.badge-marketing {
		background: #eaf2dd;
		color: #3a5a1a;
	}

		.badge-lecture {
		background: #eaf2dd;
		color: #7f8961;
	}

	.hidden {
		display: none;
	}

	@media (max-width: 720px) {
		.hero h1 { font-size: 1.9rem; }
		.featured-card { grid-template-columns: 1fr; }
		.featured-img { min-height: 200px; }
		.post-grid { grid-template-columns: 1fr; }
	}
</style>

<script>
	const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
	const featured = document.querySelector<HTMLElement>('.featured-card');
	const cards = document.querySelectorAll<HTMLElement>('.post-card');

	buttons.forEach((btn) => {
		btn.addEventListener('click', () => {
			buttons.forEach((b) => b.classList.remove('active'));
			btn.classList.add('active');

			const filter = btn.dataset.filter ?? 'tous';

			if (featured) {
				const cat = featured.dataset.category ?? '';
				featured.classList.toggle('hidden', filter !== 'tous' && cat !== filter);
			}

			cards.forEach((card) => {
				const cat = card.dataset.category ?? '';
				card.classList.toggle('hidden', filter !== 'tous' && cat !== filter);
			});
		});
	});
</script>