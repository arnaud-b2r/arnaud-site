---
/**
 * blog/index.astro — Page archives du blog
 * Design dark mode harmonisé avec la homepage.
 * Structure conservée : hero, filtres, featured card, grille.
 * Seul le design change — la logique JS de filtrage est intacte.
 */
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featured = posts[0];
const rest = posts.slice(1);
---

<MainLayout title="Articles — Arnaud Borderiou">

  <!-- ============================================================
       HERO DE LA PAGE ARTICLES
       Même structure que la homepage : kicker + grand titre.
       Plus sobre — pas d'asymétrie ni de stats, juste l'accroche.
       ============================================================ -->
  <section class="blog-hero">
    <div class="blog-hero-inner">
      <p class="kicker">
        <span class="kicker-dot"></span>
        Archives
      </p>
      <h1>Journal <em>de bord</em></h1>
      <p class="intro">
        Notes, réflexions et articles autour de la tech, du marketing et du numérique.
      </p>
    </div>
  </section>

  <!-- ============================================================
       FILTRES PAR CATÉGORIE
       Style "pill" discret — fond transparent, bordure fine.
       Actif : fond accent terre cuite.
       ============================================================ -->
  <div class="blog-filters-wrap">
    <div class="filters">
      <button class="filter-btn active" data-filter="tous">Tous</button>
      <button class="filter-btn" data-filter="tech">Tech</button>
      <button class="filter-btn" data-filter="voyage">Voyage</button>
      <button class="filter-btn" data-filter="marketing">Marketing</button>
      <button class="filter-btn" data-filter="lecture">Lecture</button>
    </div>
  </div>

  <!-- ============================================================
       ARTICLE À LA UNE
       Grille 50/50 : image gauche, texte droite.
       Même technique gouttière 1px que la homepage — pas de border-radius,
       les éléments sont jointifs pour un rendu magazine.
       ============================================================ -->
  {featured && (
    <div class="featured-wrap">
      <a
        href={`/blog/${featured.id}/`}
        class="featured-card"
        data-category={featured.data.category?.toLowerCase() ?? ''}
      >
        <!-- Image -->
        <div class="featured-img">
          {featured.data.heroImage
            ? <img src={featured.data.heroImage} alt={featured.data.title} />
            : <div class="img-placeholder"></div>
          }
          {featured.data.category && (
            <span class={`badge badge-${featured.data.category.toLowerCase()}`}>
              {featured.data.category}
            </span>
          )}
        </div>

        <!-- Texte -->
        <div class="featured-content">
          <div class="featured-content-inner">
            <span class="post-date">
              <FormattedDate date={featured.data.pubDate} />
            </span>
            <h2>{featured.data.title}</h2>
            {featured.data.description && <p class="featured-desc">{featured.data.description}</p>}
            <span class="read-more">Lire la suite →</span>
          </div>
        </div>
      </a>
    </div>
  )}

  <!-- ============================================================
       GRILLE D'ARTICLES
       3 colonnes jointives — même technique que la homepage.
       ============================================================ -->
  <div class="post-grid-wrap">
    <ul class="post-grid">
      {rest.map((post) => (
        <li class="post-card" data-category={post.data.category?.toLowerCase() ?? ''}>
          <a href={`/blog/${post.id}/`} class="card-link">

            <div class="card-img">
              {post.data.heroImage
                ? <img src={post.data.heroImage} alt={post.data.title} />
                : <div class="img-placeholder"></div>
              }
              {post.data.category && (
                <span class={`badge badge-${post.data.category.toLowerCase()}`}>
                  {post.data.category}
                </span>
              )}
            </div>

            <div class="card-body">
              <p class="post-date">
                <FormattedDate date={post.data.pubDate} />
              </p>
              <h3 class="post-title">{post.data.title}</h3>
              {post.data.description && (
                <p class="post-desc">{post.data.description}</p>
              )}
            </div>

            <div class="card-footer">
              <span class="read-more">Lire</span>
            </div>

          </a>
        </li>
      ))}
    </ul>
  </div>

</MainLayout>

<style>
/* ============================================================
   HERO
   ============================================================ */

.blog-hero {
  border-bottom: 0.5px solid var(--color-border);
}

.blog-hero-inner {
  max-width: var(--content-width);
  margin: 0 auto;
  padding: 52px 40px 48px;
}

.kicker {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: var(--font-sans);
  font-size: var(--text-xs);
  font-weight: 400;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-text-faint);
  margin: 0 0 20px;
}

.kicker-dot {
  display: inline-block;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--color-accent);
  flex-shrink: 0;
}

.blog-hero-inner h1 {
  font-family: var(--font-serif);
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 900;
  line-height: 1.0;
  letter-spacing: -0.02em;
  color: var(--color-text);
  margin: 0 0 16px;
}

.blog-hero-inner h1 em {
  color: var(--color-accent);
  font-style: italic;
}

.intro {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: 300;
  color: var(--color-text-muted);
  margin: 0;
  max-width: 52ch;
}

/* ============================================================
   FILTRES
   ============================================================ */

.blog-filters-wrap {
  max-width: var(--content-width);
  margin: 0 auto;
  padding: 24px 40px;
  border-bottom: 0.5px solid var(--color-border);
}

.filters {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.filter-btn {
  padding: 6px 18px;
  border-radius: 2px;
  font-family: var(--font-sans);
  font-size: 10px;
  font-weight: 400;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: 0.5px solid var(--color-border-mid);
  background: transparent;
  color: var(--color-text-faint);
  cursor: pointer;
  transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
}

.filter-btn:hover {
  border-color: rgba(250,250,247,0.3);
  color: var(--color-text);
}

.filter-btn.active {
  background: var(--color-accent);
  color: var(--color-bg);
  border-color: var(--color-accent);
  font-weight: 500;
}

/* ============================================================
   FEATURED CARD
   ============================================================ */

.featured-wrap {
  max-width: var(--content-width);
  margin: 0 auto;
  border-bottom: 0.5px solid var(--color-border);
}

.featured-card {
  display: grid;
  grid-template-columns: 1fr 1fr;
  text-decoration: none;
  color: inherit;
  /* Gouttière 1px entre image et texte */
  gap: 1px;
  background: var(--color-border);
  transition: background 0.15s ease;
}

.featured-card:hover {
  background: rgba(232,113,74,0.2);
  text-decoration: none;
}

/* Image */
.featured-img {
  position: relative;
  min-height: 340px;
  background: var(--color-bg-subtle);
  overflow: hidden;
}

.featured-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  filter: brightness(0.88);
  transition: filter 0.2s ease;
}

.featured-card:hover .featured-img img {
  filter: brightness(1);
}

/* Panneau texte */
.featured-content {
  background: var(--color-bg);
  display: flex;
  align-items: center;
  padding: 48px 44px;
  transition: background 0.15s ease;
}

.featured-card:hover .featured-content {
  background: var(--color-bg-raised);
}

.featured-content-inner {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.featured-content-inner h2 {
  font-family: var(--font-serif);
  font-size: clamp(1.3rem, 2vw, 1.75rem);
  font-weight: 700;
  color: var(--color-text);
  line-height: var(--leading-snug);
  margin: 0;
}

.featured-desc {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: 300;
  color: var(--color-text-muted);
  line-height: var(--leading-normal);
  margin: 0;
}

/* ============================================================
   GRILLE D'ARTICLES
   Même technique gouttière 1px que la homepage.
   ============================================================ */

.post-grid-wrap {
  max-width: var(--content-width);
  margin: 0 auto;
}

.post-grid {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1px;
  background: var(--color-border);
  border-bottom: 0.5px solid var(--color-border);
}

.post-card {
  background: var(--color-bg);
  transition: background 0.15s ease;
}

.post-card:hover {
  background: var(--color-bg-raised);
}

.card-link {
  display: flex;
  flex-direction: column;
  height: 100%;
  text-decoration: none;
  color: inherit;
}

.card-link:hover {
  text-decoration: none;
}

.card-img {
  position: relative;
  height: 180px;
  background: var(--color-bg-subtle);
  overflow: hidden;
  flex-shrink: 0;
}

.card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  filter: brightness(0.85);
  transition: filter 0.2s ease;
}

.post-card:hover .card-img img {
  filter: brightness(0.95);
}

.img-placeholder {
  width: 100%;
  height: 100%;
  background: var(--color-bg-subtle);
}

.card-body {
  padding: 20px 22px 16px;
  flex: 1;
}

.post-date {
  font-family: var(--font-sans);
  font-size: 10px;
  font-weight: 400;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-text-faint);
  margin: 0 0 10px;
}

.post-title {
  font-family: var(--font-serif);
  font-size: var(--text-base);
  font-weight: 700;
  line-height: var(--leading-snug);
  color: var(--color-text);
  margin: 0 0 10px;
}

.post-desc {
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  font-weight: 300;
  line-height: var(--leading-normal);
  color: var(--color-text-muted);
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-footer {
  padding: 12px 22px;
  border-top: 0.5px solid var(--color-border);
}

.read-more {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-sans);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-accent);
  text-decoration: none;
}

.read-more::after {
  content: '→';
}

/* ============================================================
   BADGES DE CATÉGORIE
   Identiques à la homepage — réutiliser les mêmes valeurs.
   ============================================================ */

.badge {
  position: absolute;
  top: 12px;
  left: 12px;
  font-family: var(--font-sans);
  font-size: 9px;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: var(--radius-sm);
}

.badge-marketing {
  background: rgba(232,113,74,0.15);
  color: var(--color-accent);
  border: 0.5px solid rgba(232,113,74,0.3);
}

.badge-tech {
  background: rgba(74,124,111,0.15);
  color: var(--color-jade);
  border: 0.5px solid rgba(74,124,111,0.3);
}

.badge-voyage {
  background: rgba(74,124,111,0.15);
  color: var(--color-jade);
  border: 0.5px solid rgba(74,124,111,0.3);
}

.badge-lecture {
  background: rgba(74,124,111,0.15);
  color: var(--color-jade);
  border: 0.5px solid rgba(74,124,111,0.3);
}

.badge-ia {
  background: rgba(26,58,74,0.4);
  color: #6AA8C0;
  border: 0.5px solid rgba(106,168,192,0.25);
}

.hidden {
  display: none !important;
}

/* ============================================================
   RESPONSIVE
   ============================================================ */

@media (max-width: 1024px) {
  .post-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 768px) {
  .blog-hero-inner {
    padding: 40px 24px 36px;
  }

  .blog-filters-wrap {
    padding: 20px 24px;
  }

  .featured-card {
    grid-template-columns: 1fr;
  }

  .featured-img {
    min-height: 220px;
  }

  .featured-content {
    padding: 32px 24px;
  }

  .post-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 480px) {
  .blog-hero-inner h1 {
    font-size: 2.2rem;
  }

  .blog-filters-wrap {
    padding: 16px 20px;
  }
}
</style>

<script>
  /*
   * Filtrage par catégorie — logique inchangée.
   * Un clic sur un bouton filtre : affiche uniquement les articles
   * dont data-category correspond. "tous" affiche tout.
   */
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const featured = document.querySelector<HTMLElement>('.featured-card');
  const cards = document.querySelectorAll<HTMLElement>('.post-card');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      const filter = btn.dataset.filter ?? 'tous';

      if (featured) {
        const cat = featured.dataset.category ?? '';
        featured.classList.toggle('hidden', filter !== 'tous' && cat !== filter);
      }

      cards.forEach((card) => {
        const cat = card.dataset.category ?? '';
        card.classList.toggle('hidden', filter !== 'tous' && cat !== filter);
      });
    });
  });
</script>
