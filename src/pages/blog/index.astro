---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<MainLayout>
	<section class="hero">
		<p class="eyebrow">Archives</p>

		<h1>Blog</h1>

		<p class="intro">
			Retrouve ici mes notes, réflexions et articles publiés sur Notes de bord,
			autour de la tech, du marketing et du numérique.
		</p>
	</section>

	<section class="posts-section">
		<ul class="post-grid">
			{posts.map((post) => (
				<li class="post-card">
					<a href={`/blog/${post.id}/`}>
						<p class="post-date">
							<FormattedDate date={post.data.pubDate} />
						</p>

						<h2 class="post-title">{post.data.title}</h2>

						{post.data.description && (
							<p class="post-description">{post.data.description}</p>
						)}
					</a>
				</li>
			))}
		</ul>
	</section>

	<style>
		/*
		  Hero = bloc d’introduction de la page blog.
		  Même logique visuelle que sur la home pour garder une cohérence.
		*/
		.hero {
			padding: 1rem 0 2.5rem 0;
		}

		/*
		  Eyebrow = petit libellé au-dessus du titre principal.
		  Sert à contextualiser la page.
		*/
		.eyebrow {
			margin: 0 0 0.75rem 0;
			font-size: 0.9rem;
			font-weight: 600;
			letter-spacing: 0.08em;
			text-transform: uppercase;
			color: rgb(var(--accent));
		}

		.hero h1 {
			margin: 0 0 1rem 0;
			font-size: 3rem;
			line-height: 1.05;
			color: rgb(var(--black));
		}

		.intro {
			max-width: 720px;
			margin: 0;
			font-size: 1.05rem;
			color: rgb(var(--gray));
		}

		/*
		  post-grid = grille des cartes d’articles.
		  Deux colonnes sur desktop, une seule sur mobile.
		*/
		.post-grid {
			list-style: none;
			padding: 0;
			margin: 0;
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 1.5rem;
		}

		/*
		  post-card = carte individuelle d’un article.
		  Fond blanc, bord discret, légère élévation au survol.
		*/
		.post-card {
			border: 1px solid rgba(var(--gray), 0.18);
			border-radius: 16px;
			background: white;
			transition:
				transform 0.2s ease,
				box-shadow 0.2s ease,
				border-color 0.2s ease;
		}

		/*
		  On met le premier article légèrement en avant.
		*/
		.post-card:first-child {
			grid-column: 1 / -1;
		}

		.post-card:hover {
			transform: translateY(-3px);
			box-shadow: var(--box-shadow);
			border-color: rgba(var(--accent), 0.25);
		}

		/*
		  Le lien occupe toute la carte.
		*/
		.post-card a {
			display: block;
			padding: 1.4rem;
			text-decoration: none;
			color: inherit;
		}

		.post-date {
			margin: 0 0 0.65rem 0;
			font-size: 0.92rem;
			font-weight: 500;
			color: rgb(var(--gray));
		}

		.post-title {
			margin: 0 0 0.75rem 0;
			font-size: 1.5rem;
			line-height: 1.2;
			color: rgb(var(--black));
		}

		.post-description {
			margin: 0;
			font-size: 1rem;
			line-height: 1.6;
			color: rgb(var(--gray-dark));
		}

		/*
		  Mobile : une seule colonne et titre un peu réduit.
		*/
		@media (max-width: 720px) {
			.hero {
				padding: 0.5rem 0 2rem 0;
			}

			.hero h1 {
				font-size: 2.3rem;
			}

			.post-grid {
				grid-template-columns: 1fr;
			}

			.post-card:first-child {
				grid-column: auto;
			}

			.post-title {
				font-size: 1.3rem;
			}
		}
	</style>
</MainLayout>