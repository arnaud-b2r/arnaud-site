---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<!-- Titre du site / logo texte -->
		<h2 class="site-title">
			<a href="/" class="logo-link">
			<img src="/images/carnet-bord_logo.png" alt="Carnet de bord" class="logo" />
			<span>{SITE_TITLE}</span>
			</a>
		</h2>

		<!-- Navigation principale -->
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<!-- HeaderLink href="/blog">Blog</HeaderLink>-->
			<!--HeaderLink href="/about">About</HeaderLink-->
		</div>
	</nav>
</header>

<style>
	/* 
	  Le header reste visible en haut quand on scrolle.
	  "sticky" colle l'élément en haut sans le sortir complètement du flux.
	*/
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		padding: 0 1.5rem;
		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		border-bottom: 1px solid rgba(var(--gray), 0.18);
	}

	/* 
	  Conteneur principal du menu :
	  - largeur cohérente avec le reste du site
	  - alignement horizontal
	  - hauteur confortable
	*/
	nav {
		max-width: 1100px;
		margin: 0 auto;
		min-height: 72px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
	}

	/* Titre du site */
	.site-title {
		margin: 0;
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.2;
	}

	.logo-link {
	display: flex;
	align-items: center;
	gap: 0.5rem;
	}

	.logo {
		height: 32px;
		width: auto;
		display: block;
	}

	.site-title a,
	.site-title a:hover,
	.site-title a:visited {
		color: rgb(var(--black));
		text-decoration: none;
	}

	/* Navigation interne */
	.internal-links {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	/* 
	  Style global des liens dans le header.
	  Le border-bottom sert d'indicateur d'onglet actif.
	*/
	nav a {
		padding: 1.25rem 0;
		color: rgb(var(--gray-dark));
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-weight: 500;
		transition:
			color 0.2s ease,
			border-color 0.2s ease;
	}

	/* Survol */
	nav a:hover {
		color: rgb(var(--accent));
		text-decoration: none;
	}

	/* Lien actif */
	nav a.active {
		color: rgb(var(--black));
		border-bottom-color: rgb(var(--accent));
		text-decoration: none;
	}

	/* Version mobile : on garde simple et lisible */
	@media (max-width: 720px) {
		header {
			padding: 0 1rem;
		}

		nav {
			min-height: 64px;
			gap: 1rem;
		}

		.site-title {
			font-size: 0.95rem;
		}

		.internal-links {
			gap: 1rem;
		}
	}
</style>