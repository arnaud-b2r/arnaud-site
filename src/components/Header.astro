---
const currentPath = Astro.url.pathname;
---

<header>
  <div class="header-inner">
    <a href="/" class="brand">
      <div class="logo-circle">
        <img src="/images/carnet-bord_logo_blanc.png" alt="Logo" />
      </div>
      <div>
        <span class="site-name">CARNET DE BORD</span>
        <span class="site-sub">par Arnaud Borderiou</span>
      </div>
    </a>
    <nav>
      <a href="/" aria-current={currentPath === "/" ? "page" : undefined}>Accueil</a>
      <a href="/blog" aria-current={currentPath.startsWith("/articles") ? "page" : undefined}>Articles</a>
      <a href="/about" aria-current={currentPath === "/about" ? "page" : undefined}>À propos</a>
    </nav>
  </div>
</header>

<style>
  header {
    background: #1a3a4a;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
  }

  .logo-circle {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #f5f0e8;
    border: 2px solid #4a7a8a;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .logo-circle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .site-name {
    display: block;
    font-size: 26px;
    font-weight: 500;
    color: #f0f0f0;
    line-height: 1.1;
  }

  .site-sub {
    display: block;
    font-size: 12px;
    color: #7aaabb;
    margin-top: 2px;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  nav a {
    color: #a8c8d4;
    text-decoration: none;
    font-size: 14px;
    padding: 7px 16px;
    border-radius: 6px;
    transition: background 0.15s;
  }

  nav a:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  nav a[aria-current="page"] {
    background: #e8572a;
    color: #ffffff;
    font-weight: 500;
  }
</style>
