---
/**
 * Header.astro — Carnet de bord
 * Light mode — juin 2026
 *
 * Structure : nom du site en serif à gauche, nav à droite avec 5 items.
 * Les catégories Terrain / Curiosité / Échappées pointent vers /blog?categorie=xxx
 * La page active est signalée par la couleur accent (terracotta).
 */
const currentPath = Astro.url.pathname;

const isHome      = currentPath === '/';
const isTerrain   = currentPath.startsWith('/blog') && Astro.url.search.includes('terrain');
const isCuriosite = currentPath.startsWith('/blog') && Astro.url.search.includes('curiosite');
const isEchappees = currentPath.startsWith('/blog') && Astro.url.search.includes('echappees');
const isAbout     = currentPath === '/about';
---

<header>
  <div class="header-inner">

    <!-- Nom du site en serif à gauche -->
    <a href="/" class="brand">Carnet de bord</a>

    <!-- Navigation 5 items -->
    <nav aria-label="Navigation principale">
      <a href="/" class={isHome ? 'active' : ''} aria-current={isHome ? 'page' : undefined}>
        Accueil
      </a>
      <a href="/blog/terrain" class={isTerrain ? 'active' : ''}>
        Terrain
      </a>
      <a href="/blog/curiosite" class={isCuriosite ? 'active' : ''}>
        Curiosité
      </a>
      <a href="/blog/echappees" class={isEchappees ? 'active' : ''}>
        Échappées
      </a>
      <a href="/about" class={isAbout ? 'active' : ''} aria-current={isAbout ? 'page' : undefined}>
        À propos
      </a>
    </nav>

  </div>
</header>

<style>
  header {
    background: var(--color-bg);
    border-bottom: 0.5px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .header-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--content-padding);
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Nom du site : serif, sobre, pas de majuscules */
  .brand {
    font-family: var(--font-serif);
    font-size: 15px;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }

  .brand:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  nav a {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 6px 14px;
    border-radius: var(--radius-pill);
    transition: color 0.15s ease;
  }

  nav a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  nav a.active,
  nav a[aria-current="page"] {
    color: var(--color-accent);
    font-weight: 500;
  }

  /* Tablette : masquer les catégories, garder Accueil + À propos */
  @media (max-width: 768px) {
    .header-inner { height: 56px; }

    nav a:nth-child(2),
    nav a:nth-child(3),
    nav a:nth-child(4) {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .brand { font-size: 14px; }
    nav a { padding: 6px 10px; font-size: 12px; }
  }
</style>