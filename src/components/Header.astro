---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
    <h2 class="site-title">
      <a href="/" class="logo-link">
        <img src="/images/carnet-bord_logo_blanc.png" alt="Carnet de bord" class="logo" />
        <span>{SITE_TITLE}</span>
      </a>
    </h2>

    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <!--HeaderLink href="/blog">Blog</HeaderLink-->
      <!--HeaderLink href="/about">About</HeaderLink-->
    </div>
  </nav>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    background: rgba(223, 2, 53, 0.9);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(var(--gray), 0.18);
  }

  nav {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1rem;
    box-sizing: border-box;
    min-height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .site-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.2;
    min-width: 0;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: white;
    text-decoration: none;
    min-width: 0;
  }

  .logo {
    display: block;
    height: 32px;
    width: auto;
    flex-shrink: 0;
  }

  .site-title span {
    white-space: nowrap;
  }

  .internal-links {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  nav a {
    padding: 1rem 0;
    color: white;
    text-decoration: none;
    font-weight: 500;
    border-bottom: 2px solid transparent;
  }

  nav a:hover {
    color: rgba(255, 255, 255, 0.85);
  }

  nav a.active {
    border-bottom-color: white;
  }

  @media (max-width: 720px) {
    nav {
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.75rem 1rem;
      min-height: auto;
    }

    .site-title {
      font-size: 0.95rem;
    }

    .internal-links {
      width: 100%;
      gap: 0.75rem;
    }

    nav a {
      padding: 0.4rem 0;
    }
  }
</style>