---
/**
 * Header.astro
 * En-tête sticky — charte validée avril 2026.
 * Logo sumo en bleu encre #1A3A4A via filtre CSS temporaire.
 * Accent terre cuite #E8714A sur le lien actif.
 */
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
  <div class="header-inner">

    <!-- Marque : logo + nom éditorial + signature -->
    <a href="/" class="brand" aria-label="Carnet de bord — accueil">

      <!--
        Logo PNG avec filtre CSS pour le teinter en bleu encre.
        Astuce temporaire : quand tu auras un PNG ou SVG directement
        en bleu encre depuis ton outil de design, tu pourras
        supprimer le `filter` ci-dessous et le logo sera parfait.
      -->
      <img
        src="/images/carnet-bord_logo.png"
        alt=""
        class="brand-logo"
        aria-hidden="true"
      />

      <div class="brand-text">
        <span class="brand-name">Carnet de bord</span>
        <span class="brand-by">par Arnaud Borderiou</span>
      </div>
    </a>

    <!-- Navigation principale -->
    <nav class="nav" aria-label="Navigation principale">
      <HeaderLink href="/">Accueil</HeaderLink>
      <HeaderLink href="/blog">Articles</HeaderLink>
      <HeaderLink href="/about">À propos</HeaderLink>
    </nav>

  </div>
</header>

<style>
  /*
    Fond ivoire semi-transparent + flou au scroll.
    On écrit rgba() en valeur directe car CSS ne permet pas
    d'utiliser var() à l'intérieur de rgba() nativement.
  */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    background: rgba(250, 250, 247, 0.93);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid #D9D3C8;
  }

  .header-inner {
    width: 100%;
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  /* Marque : logo + texte côte à côte */
  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  /*
    filter: hue-rotate + saturate + brightness
    Transforme le rouge du logo PNG vers le bleu encre #1A3A4A.
    C'est une astuce CSS — le vrai fix sera d'exporter
    ton logo directement en bleu encre depuis ton logiciel de design.
  */
  .brand-logo {
    height: 32px;
    width: auto;
    display: block;
    filter: hue-rotate(185deg) saturate(0.8) brightness(0.55);
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
    line-height: 1.2;
  }

  .brand-name {
    font-family: 'Roboto Serif', Georgia, serif;
    font-size: 1.05rem;
    font-weight: 500;
    color: #1A3A4A;
    letter-spacing: -0.2px;
  }

  .brand-by {
    font-family: 'Roboto', system-ui, sans-serif;
    font-size: 0.7rem;
    color: #9B9488;
    font-style: italic;
  }

  /* Au survol : le nom passe en terre cuite */
  .brand:hover .brand-name {
    color: #E8714A;
  }

  /* Navigation */
  .nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav :global(a) {
    font-family: 'Roboto', system-ui, sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    color: #6B6560;
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    border-radius: 4px;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .nav :global(a:hover) {
    color: #1A3A4A;
    background: rgba(26, 58, 74, 0.06);
    text-decoration: none;
  }

  /*
    Lien actif : fond terre cuite très pâle + texte terre cuite.
    HeaderLink.astro ajoute automatiquement la classe .active
    en comparant l'URL courante avec le href du lien.
  */
  .nav :global(a.active) {
    color: #E8714A;
    background: #FDF0EB;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .header-inner {
      padding: 0 1rem;
      height: 56px;
    }

    .brand-name {
      font-size: 0.95rem;
    }

    .nav :global(a) {
      font-size: 0.85rem;
      padding: 0.35rem 0.5rem;
    }
  }

  @media (max-width: 400px) {
    .brand-by {
      display: none;
    }
  }
</style>