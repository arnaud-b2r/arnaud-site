---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2 class="site-title">
			<a href="/" class="logo-link">
				<img src="/images/carnet-bord_logo_blanc.png" alt="Carnet de bord" class="logo" />
				<span>{SITE_TITLE}</span>
			</a>
		</h2>

		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>

<style>
	* {
		box-sizing: border-box;
	}

	header {
		position: sticky;
		top: 0;
		z-index: 100;
		width: 100%;
		background: rgba(223, 2, 53, 0.9);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(10px);
		border-bottom: 1px solid rgba(var(--gray), 0.18);
		overflow-x: clip;
	}

	nav {
		width: 100%;
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1.5rem;
		min-height: 72px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
	}

	.site-title {
		margin: 0;
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.2;
		flex-shrink: 1;
		min-width: 0;
	}

	.logo-link {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		min-width: 0;
	}

	.logo {
		height: 32px;
		width: auto;
		display: block;
		flex-shrink: 0;
	}

	.site-title a,
	.site-title a:hover,
	.site-title a:visited {
		color: white;
		text-decoration: none;
	}

	.site-title span {
		white-space: nowrap;
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		flex-shrink: 0;
	}

	nav a {
		padding: 1.25rem 0;
		color: white;
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-weight: 500;
		transition:
			color 0.2s ease,
			border-color 0.2s ease;
	}

	nav a:hover {
		color: rgba(255, 255, 255, 0.8);
		text-decoration: none;
	}

	nav a.active {
		color: white;
		border-bottom-color: white;
		text-decoration: none;
	}

	@media (max-width: 720px) {
		nav {
			padding: 0.75rem 1rem;
			min-height: auto;
			flex-direction: column;
			align-items: flex-start;
			justify-content: center;
			gap: 0.5rem;
		}

		.site-title {
			font-size: 0.95rem;
		}

		.internal-links {
			width: 100%;
			flex-wrap: wrap;
			gap: 1rem;
		}

		nav a {
			padding: 0.4rem 0;
		}
	}
<style>
header {
  position: sticky;
  top: 0;
  z-index: 100;
  width: 100%;
  background: rgba(223, 2, 53, 0.9);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid rgba(var(--gray), 0.18);
}

/* Conteneur */
nav {
  width: 100%;
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 1rem; /* ⚠️ réduit pour éviter débordement */
  min-height: 72px;

  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem; /* ⚠️ réduit */
}

/* Logo + titre */
.site-title {
  margin: 0;
  font-size: 1rem;
  font-weight: 700;
  display: flex;
}

.logo-link {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.logo {
  height: 32px;
  width: auto;
}

.site-title a {
  color: white;
  text-decoration: none;
}

/* Navigation */
.internal-links {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap; /* ✅ important */
}

nav a {
  padding: 1rem 0;
  color: white;
  text-decoration: none;
  font-weight: 500;
  border-bottom: 2px solid transparent;
}

nav a.active {
  border-bottom-color: white;
}

/* 📱 Mobile */
@media (max-width: 720px) {
  nav {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
  }

  .internal-links {
    width: 100%;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  nav a {
    padding: 0.4rem 0;
  }
}
</style>