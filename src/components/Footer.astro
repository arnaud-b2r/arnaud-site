---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p class="footer-text">
			&copy; {today.getFullYear()} Arnaud Borderiou. Tous droits réservés.
		</p>
	</div>
</footer>

<style>
	/* 
	  Footer simple, centré et discret.
	  L’objectif est d’avoir une fin de page propre sans parasiter le contenu.
	*/
	footer {
		padding: 3rem 1.5rem;
		border-top: 1px solid rgba(var(--gray), 0.18);
		background: transparent;
	}

	/* 
	  On garde une largeur cohérente avec le header et le contenu du site.
	*/
	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		text-align: center;
	}

	/* 
	  Texte secondaire : visible, mais moins fort que le contenu principal.
	*/
	.footer-text {
		margin: 0;
		font-size: 0.95rem;
		color: rgb(var(--gray));
		line-height: 1.6;
	}
</style>