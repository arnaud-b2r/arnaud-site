---
/**
 * Footer.astro — Carnet de bord
 * Sobre : nom + copyright à gauche, 4 liens à droite.
 * Fond sombre (--color-footer-bg) pour contraster avec le reste du site.
 */
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">

    <!-- Gauche : nom + copyright -->
    <div class="footer-left">
      <span class="footer-brand">Carnet de bord</span>
      <span class="footer-copy">© {year} Arnaud Borderiou</span>
    </div>

    <!-- Droite : navigation secondaire -->
    <nav class="footer-nav" aria-label="Navigation pied de page">
      <a href="/about">À propos</a>
      <a href="/blog">Articles</a>
      <a href="/rss.xml">RSS</a>
      <a href="https://www.linkedin.com/in/arnaud-borderiou/" target="_blank" rel="noopener noreferrer">
        LinkedIn
      </a>
    </nav>

  </div>
</footer>

<style>
  footer {
    background: var(--color-footer-bg);
    border-top: none;
  }

  .footer-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 20px var(--content-padding);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .footer-brand {
    font-family: var(--font-serif);
    font-size: 13px;
    font-weight: 700;
    color: #FAFAF8;
    letter-spacing: -0.01em;
  }

  .footer-copy {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    color: rgba(250, 250, 248, 0.35);
    letter-spacing: 0.02em;
  }

  .footer-nav {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .footer-nav a {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(250, 250, 248, 0.45);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-nav a:hover {
    color: rgba(250, 250, 248, 0.85);
    text-decoration: none;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
      padding: 24px var(--content-padding);
    }

    .footer-nav {
      gap: 16px;
    }
  }
</style>