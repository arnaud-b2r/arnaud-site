---
/**
 * Footer.astro
 * Pied de page — dark mode cohérent avec la homepage.
 * Fond légèrement plus sombre que la page pour créer une
 * sensation de "sol" visuel sans rupture brutale.
 */
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">

    <!-- Marque -->
    <div class="footer-brand">
      <span class="footer-name">Carnet de bord</span>
      <span class="footer-copy">&copy; {year} Arnaud Borderiou</span>
    </div>

    <!-- Liens secondaires -->
    <nav class="footer-nav" aria-label="Navigation secondaire">
      <a href="/about">À propos</a>
      <a href="/blog">Articles</a>
      <a href="/rss.xml">RSS</a>
      <a
        href="https://www.linkedin.com/in/arnaudborderiou/"
        target="_blank"
        rel="noopener noreferrer"
      >
        LinkedIn
      </a>
    </nav>

  </div>
</footer>

<style>
  .site-footer {
    /*
      #0A0A09 : légèrement plus sombre que le fond principal #0D0D0B.
      Cette différence subtile (~3 niveaux) suffit à marquer la frontière
      bas de page sans introduire une rupture agressive.
    */
    background: #0A0A09;
    border-top: 0.5px solid rgba(250,250,247,0.07);
    padding: 28px 0;
    margin-top: auto;
  }

  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  /* --- Marque --- */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .footer-name {
    font-family: 'Roboto Serif', Georgia, serif;
    font-size: 13px;
    font-weight: 700;
    color: rgba(250,250,247,0.6);
    letter-spacing: 0.02em;
  }

  .footer-copy {
    font-family: 'Roboto', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 300;
    color: rgba(250,250,247,0.2);
    letter-spacing: 0.04em;
  }

  /* --- Navigation --- */
  .footer-nav {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .footer-nav a {
    font-family: 'Roboto', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(250,250,247,0.25);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-nav a:hover {
    color: #E8714A;
    text-decoration: none;
  }

  /* --- Responsive --- */
  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
      padding: 0 20px;
    }

    .footer-nav {
      gap: 16px;
      flex-wrap: wrap;
    }
  }
</style>
